# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Claude Code: ignore only per-user / vendored bits; shared config is checked in
.claude/skills/
.claude/settings.local.json

# macOS Finder metadata
.DS_Store

# Python (uv)
.venv/
__pycache__/
*.pyc
.mypy_cache/
.ruff_cache/

# Data boundary — generated EOS/opacity tables (JSON) and raw sweep results (JSONL)
# are produced by `make tables` / `make sweep` and are NOT checked in.
/data/*
# ...EXCEPT the small deliverable artifacts that CONCLUSION.md cites as its evidence:
# the frontier CSVs (the quoted numbers) and the result figures. The study is wrapped,
# so these can't be assumed regenerable on a fresh clone — they are committed in place
# as the single source of truth. See ADR-0025.
!/data/results/
/data/results/*
!/data/results/frontier*.csv
!/data/results/shape_sensitivity.csv
!/data/results/shape_frozen_spotcheck.csv
!/data/results/*.png
# ...and the raw TOPS/OPLIB opacity pull (ADR-0007 amendment): the citable provenance
# artifact behind the 69 km/s table; needs a network allow to re-fetch (`make fetch-tops`).
!/data/tables/
/data/tables/*
!/data/tables/tops/

# Scratch space for temporary working files shared with Claude (e.g. checklists
# for completing a single task). Disposable; never checked in.
/todos/
